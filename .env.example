# ── NarayanAstroReader — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local dev you can use SQLite by leaving
# DATABASE_URL blank — the app falls back to narayan_astro.db in the project root.
DATABASE_URL=postgresql://user:password@localhost:5432/narayan_astro

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_32_char_hex_string

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── Email (SMTP) — leave blank to print verification links to the console ─────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM_NAME=NarayanAstroReader

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000

# ── Payment gateway (leave blank for mock/dev mode — no real payments needed) ─
# PAYMENT_GATEWAY=razorpay          # or: stripe
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── PyJHora path (Vedic astrology engine) ────────────────────────────────────
# Absolute path to the PyJHora/src directory on this machine.
# Clone from: https://github.com/alyssNitin/PyJHora.git
# Example paths:
#   Windows : C:\Users\yourname\PyJHora\src
#   Mac/Linux: /home/yourname/PyJHora/src
PYJHORA_PATH=C:\Users\yourname\PyJHora\src

# ── Microservices (leave false for monolith mode) ────────────────────────────
USE_MICROSERVICES=false

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# REDIS_URL=redis://localhost:6379/0
