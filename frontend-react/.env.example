# frontend-react/.env.example
# ============================
# Copy this file to .env.local and fill in values.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Optional: Override the API base URL (default: same origin as the dev server proxy)
# In production this is usually empty — the React app is served from the same domain as FastAPI.
VITE_API_BASE_URL=

# Optional: Google OAuth Client ID for "Sign in with Google" button
VITE_GOOGLE_CLIENT_ID=
